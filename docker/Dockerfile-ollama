# Use the official Ollama base image
FROM ollama/ollama:latest

# Optional: Set environment variables (e.g., to change the host/port)
ENV OLLAMA_HOST=0.0.0.0

# Inicializa o Ollama temporariamente durante o build para baixar o modelo
RUN ollama serve & sleep 5 && ollama pull llama3

# Define o comando padrão para rodar o servidor
ENTRYPOINT ["ollama", "serve"]

# Expose the default Ollama API port
EXPOSE 11434

# (Optional) If you want to pre-download a model during build time:
# RUN ollama serve & sleep 5 && ollama run llama3